{
  "name": "skinnbone-website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node_modules\\.bin\\tsc.cmd && node_modules\\.bin\\vite.cmd build",
    "preview": "vite preview",
    "predeploy": "npm run build && node -e \"const fs = require('fs'); fs.copyFileSync('CNAME', 'dist/CNAME');\"",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "gh-pages": "^5.0.0",
    "typescript": "^5.6.2",
    "vite": "^5.4.0"
  }
}
